# =============================================================================
# backend/.env.example  —  copy to .env and fill in your values
# =============================================================================

# --- Doctor identity ---------------------------------------------------------
DOCTOR_PHONE=919XXXXXXXXX          # E.164 format, no '+' — e.g. 919876543210
DOCTOR_NAME="Dr. Your Name"

# --- WhatsApp worker ---------------------------------------------------------
WHATSAPP_WORKER_URL=http://localhost:3001
WHATSAPP_MODE=mock                 # 'mock' for local dev, 'live' for production

# --- Google People API -------------------------------------------------------
# Create OAuth 2.0 credentials at https://console.cloud.google.com
# Redirect URI must match exactly: http://localhost:8000/oauth2callback
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/oauth2callback
GOOGLE_REFRESH_TOKEN=              # populated automatically after first OAuth flow

# --- OTP settings ------------------------------------------------------------
OTP_TTL_SECONDS=300                # OTP validity window in seconds (default: 5 min)
OTP_RESEND_COOLDOWN_SECONDS=59     # minimum gap between resend requests

# --- Patient session ---------------------------------------------------------
SESSION_INACTIVITY_MINUTES=10      # patient session expires after this many idle minutes

# --- Doctor emergency PIN ----------------------------------------------------
# Generate with: python -c "import bcrypt; print(bcrypt.hashpw(b'YOUR_PIN', bcrypt.gensalt()).decode())"
DOCTOR_EMERGENCY_PIN_HASH=         # bcrypt hash of your chosen emergency PIN

# --- Database ----------------------------------------------------------------
DATABASE_PATH=data/clinic.db       # relative to backend/; directory must exist

# --- CORS --------------------------------------------------------------------
CORS_ORIGINS=http://localhost:5173 # frontend dev server; comma-separate multiple origins

# --- Security ----------------------------------------------------------------
SESSION_SECRET_KEY=change-this-to-a-random-string-of-at-least-32-characters
